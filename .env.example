# ====================================
# CONFIGURACIÓN GENERAL
# ====================================
NODE_ENV=production
PORT=5000

# ====================================
# BASE DE DATOS POSTGRESQL
# ====================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ayudatica_db
DB_USER=ayudatica_user
DB_PASSWORD=CAMBIAR_EN_PRODUCCION_PASSWORD_SEGURO_123

# ====================================
# JWT AUTENTICACIÓN
# ====================================
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTE_SECRET_POR_UNO_ALEATORIO_MUY_LARGO_Y_SEGURO
JWT_EXPIRES_IN=7d

# ====================================
# FRONTEND
# ====================================
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_APP_NAME=Ayuda Tica
REACT_APP_DOMAIN=ayudatica.srwangcr.tech

# Mapas - Dejar vacío para usar OpenStreetMap (gratis)
# O agregar API key de Google Maps si prefieres
REACT_APP_GOOGLE_MAPS_API_KEY=

# ====================================
# EMAIL (Gmail SMTP)
# ====================================
# 1. Ir a https://myaccount.google.com/security
# 2. Habilitar verificación en 2 pasos
# 3. Crear "App Password" para "Mail"
# 4. Usar ese password aquí
# Variables recomendadas (Gmail)
GMAIL_USER=tu-email@gmail.com
GMAIL_APP_PASSWORD=tu-app-password-de-16-caracteres
GMAIL_FROM_NAME=Ayuda Tica
GMAIL_FROM_EMAIL=tu-email@gmail.com

# Variables legacy (compatibilidad)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-de-16-caracteres
SMTP_FROM_NAME=Ayuda Tica
SMTP_FROM_EMAIL=noreply@ayudatica.srwangcr.tech

# ====================================
# SUBIDA DE ARCHIVOS
# ====================================
# Tamaño máximo de archivo en MB
MAX_FILE_SIZE=10
# Tipos de archivo permitidos (separados por coma)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# ====================================
# RATE LIMITING (Anti-DDoS básico)
# ====================================
# Máximo de requests por ventana de tiempo
RATE_LIMIT_MAX=100
# Ventana de tiempo en minutos
RATE_LIMIT_WINDOW=15

# ====================================
# CLOUDFLARE TUNNEL (Opcional)
# ====================================
# Si usas Cloudflare Tunnel, el tunnel se encarga del SSL
# No necesitas configurar SSL en Nginx directamente
CLOUDFLARE_TUNNEL_URL=https://ayudatica.srwangcr.tech

# ====================================
# NOTIFICACIONES
# ====================================
# Email del administrador para notificaciones críticas
ADMIN_EMAIL=admin@ayudatica.srwangcr.tech

# Emails de autoridades que recibirán reportes Ley 7600 (separados por coma)
AUTORIDADES_EMAILS=autoridad1@example.com,autoridad2@example.com

# ====================================
# DESARROLLO (Solo para environment local)
# ====================================
# Descomentar para desarrollo local
# DB_HOST=localhost
# REACT_APP_API_URL=http://localhost:5000/api
